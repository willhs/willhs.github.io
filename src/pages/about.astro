---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="about" description="About will hs" />
  </head>
  <body>
    <Header />
    <main class="container">
      <h1>about</h1>
      <p>
        I'm Will. Software engineer, eight years in, mostly full-stack web. I
        like making things that are a little weird — tools, games, small
        experiments — and writing them up afterwards.
      </p>
      <p>
        This site is a working notebook, not a portfolio. Expect project
        writeups, half-formed ideas, and the occasional deep dive into
        something that caught my attention.
      </p>
      <p>
        Find me at <a href="https://github.com/willhs">github.com/willhs</a>.
      </p>
    </main>
  </body>
</html>
